# Lovable Cloud / Supabase — chaves públicas do cliente
# Estas chaves NÃO são secretas: elas são embutidas no bundle do frontend.
# A segurança real vem das policies de RLS no banco.
#
# Para rodar contra o projeto atual, copie os valores do painel
# Lovable Cloud > Settings, ou use seu próprio projeto Supabase.

VITE_SUPABASE_PROJECT_ID="seu-project-ref"
VITE_SUPABASE_URL="https://seu-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key-publica"